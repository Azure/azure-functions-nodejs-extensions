  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@azure/functions": "4.15.1-preview",
    "@azure/functions-extensions-connectors": "0.0.1-preview",
    "@azure/connectors": "0.1.1-preview"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
