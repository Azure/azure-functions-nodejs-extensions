{
  "name": "@azure/functions-extensions-connectors",
  "version": "0.0.1-preview",
  "description": "Azure Functions Connectors Extension - SDK binding for Azure Logic Apps connectors",
  "main": "./dist/azure-functions-extensions-connectors.js",
  "module": "./dist/azure-functions-extensions-connectors.mjs",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "default": "./dist/azure-functions-extensions-connectors.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/azure-functions-extensions-connectors.js"
      }
    }
  },
  "sideEffects": true,
  "scripts": {
    "build": "webpack --mode development",
    "build:prod": "webpack --mode production",
    "lint": "eslint src test --ext .ts",
    "test": "mocha",
    "watch": "webpack --mode development --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "azure",
    "functions",
    "connectors",
    "office365",
    "sharepoint",
    "teams"
  ],
  "license": "MIT",
  "dependencies": {
    "@azure/connectors": "^0.1.1-preview"
  },
  "peerDependencies": {
    "@azure/functions": "4.15.0-preview"
  },
  "devDependencies": {
    "@azure/functions": "4.15.0-preview",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "eslint-webpack-plugin": "^4.0.0",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "mocha": "^10.0.0",
    "sinon": "^15.0.0",
    "ts-loader": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  }
}
