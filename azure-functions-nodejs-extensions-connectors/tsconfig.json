{
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "bundler",
        "target": "es2022",
        "strict": true,
        "noUnusedLocals": true,
        "noUncheckedIndexedAccess": true,
        "esModuleInterop": true,
        "outDir": "out",
        "sourceMap": true,
        "baseUrl": "./",
        "paths": {
            "@azure/functions-extensions-connectors": ["types"]
        }
    },
    "exclude": ["samples/**/*", "node_modules", "dist"]
}
